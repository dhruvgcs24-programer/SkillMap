<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <View
        android:id="@+id/splashBlurBlue"
        android:layout_width="450dp"
        android:layout_height="450dp"
        android:layout_marginStart="-200dp"
        android:layout_marginTop="-100dp"
        android:background="@drawable/bg_blur_blue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/splashBlurPurple"
        android:layout_width="450dp"
        android:layout_height="450dp"
        android:layout_marginEnd="-150dp"
        android:layout_marginTop="100dp"
        android:background="@drawable/bg_blur_purple"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivSplashLogo"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:contentDescription="@string/todo1"
        android:src="@drawable/skillmap_logo"
        android:alpha="0"
        android:scaleX="0.5"
        android:scaleY="0.5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>