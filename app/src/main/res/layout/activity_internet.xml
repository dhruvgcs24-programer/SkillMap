            <ImageView
                android:id="@+id/tick6"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/checkbox_on_background"
                android:visibility="gone"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>